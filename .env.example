# ============================================
# IntentForge AI — Environment Contract
# ============================================

# Application
APP_NAME=IntentForge AI
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.0.1

# Backend
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
WEB_PORT=5173

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=intentforge_db
POSTGRES_USER=intentforge
POSTGRES_PASSWORD=change_me

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Graph Database
GRAPH_DATABASE_ENABLED=false

# AI Provider
AI_PROVIDER=
AI_API_KEY=

# Observability
LOG_LEVEL=INFO
ENABLE_TRACING=true

# Security
SECRET_KEY=change_me
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Execution
SANDBOX_ENABLED=false
