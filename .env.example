# ============================================
# IntentForge AI — Environment Contract
# ============================================

# ============================================
# Active Runtime Configuration
# Implemented and validated by M2 Settings
# ============================================

# Application
APP_NAME=IntentForge AI
APP_VERSION=0.1.0
APP_ENVIRONMENT=development
APP_DEBUG=true

# Backend API
API_HOST=127.0.0.1
API_PORT=8010

# Observability
LOG_LEVEL=INFO

# Database
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=intentforge_db
POSTGRES_USER=intentforge
POSTGRES_PASSWORD=change_me

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_TIMEOUT_SECONDS=5.0


# ============================================
# Reserved Future Configuration
# Not yet consumed by the application runtime
# ============================================

# Frontend
WEB_PORT=5173

# Graph Capabilities
GRAPH_DATABASE_ENABLED=false

# AI Provider
AI_PROVIDER=
AI_API_KEY=

# Future Observability
ENABLE_TRACING=true

# Security
SECRET_KEY=change_me
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Execution
SANDBOX_ENABLED=false
